+//=================================================================================================
+// Propagate and check:
+bool Solver::prop_check(const vec<Lit>& assumps, vec<Lit>& prop, int psaving)
+{
+    prop.clear();
 
+    if (!ok)
+        return false;
+
+    bool    st = true;
+    int  level = decisionLevel();
+    CRef confl = CRef_Undef;
+
+    // dealing with phase saving
+    int psaving_copy = phase_saving;
+    phase_saving = psaving;
+
+    // propagate each assumption at a new decision level
+    for (int i = 0; st && confl == CRef_Undef && i < assumps.size(); ++i) {
+        Lit p = assumps[i];
+
+        if (value(p) == mep_l_False)
+            st = false;
+        else if (value(p) != mep_l_True) {
+            newDecisionLevel ();
+            uncheckedEnqueue(p);
+
+            if (external_propagator) {
+                while (true) {
+                    confl = propagate();
+                    if (confl != CRef_Undef) break;
+
+                    if (notify_assignment_index < trail.size()) {
+                        std::vector<int> new_assignments;
+                        while(notify_assignment_index < trail.size()) {
+                            Lit trail_lit = trail[notify_assignment_index++];
+                            if (is_observed[var(trail_lit)])
+                                new_assignments.push_back(LitToint(trail_lit));
+                        }
+                        if (!new_assignments.empty())
+                            external_propagator->notify_assignment(new_assignments);
+                    }
+
+                    int lit = external_propagator->cb_propagate();
+                    if (lit == 0) break;
+                    Lit l = intToLit(lit);
+                    if (value(l) != mep_l_Undef) continue;
+                    uncheckedEnqueue(l, sign(l) ? CRef_External_False : CRef_External_True);
+
+                    if (is_observed[var(l)]) {
+                        external_propagator->notify_assignment({lit});
+                    }
+                    notify_assignment_index++;
+                }
+            } else {
+                confl = propagate();
+            }
+        }
+    }
+
+    // copying the result
+    if (decisionLevel() > level) {
+        for (int c = trail_lim[level]; c < trail.size(); ++c)
+            prop.push(trail[c]);
+
+        // if there is a conflict, pushing
+        // the conflicting literal as well
+        if (confl != CRef_Undef)
+            prop.push(ca[confl][0]);
+
+        // backtracking
+        cancelUntil(level);
+    }
+
+    // restoring phase saving
+    phase_saving = psaving_copy;
+
+    return st && confl == CRef_Undef;
+}
