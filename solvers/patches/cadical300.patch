diff -Naur solvers/cadical300/Makefile solvers/cdc300/Makefile
--- solvers/cadical300/Makefile	1970-01-01 10:00:00
+++ solvers/cdc300/Makefile	2026-05-13 16:19:43
@@ -0,0 +1,53 @@
+### Makefile ---
+
+## Author: aign
+## Keywords:
+
+# main parameters
+CC       := cc
+CXX      := c++
+CFLAGS   := -fPIC -Wall -DQUIET -DNCLOSEFROM
+CXXFLAGS := -std=c++11 -fPIC -Wall -Wno-deprecated -fno-strict-aliasing -DQUIET -DNCLOSEFROM
+CXXOPT   := -O3 -DNDEBUG
+CXXDEBUG := -O0 -g3
+CXXPROF  := -O3 -g3 -fno-inline -fno-omit-frame-pointer -pg -DNDEBUG
+INCLUDES := -I.
+LIBS     := -L.
+SOURCES  := analyze.cpp arena.cpp assume.cpp averages.cpp backbone.cpp backtrack.cpp backward.cpp bins.cpp block.cpp checker.cpp clause.cpp collect.cpp compact.cpp condition.cpp config.cpp congruence.cpp constrain.cpp contract.cpp cover.cpp decide.cpp decompose.cpp deduplicate.cpp definition.cpp drattracer.cpp elim.cpp elimfast.cpp ema.cpp extend.cpp external.cpp external_propagate.cpp factor.cpp file0.cpp flags.cpp flip.cpp format.cpp frattracer.cpp gates.cpp idruptracer.cpp instantiate.cpp internal.cpp lidruptracer.cpp limit.cpp logging.cpp lookahead.cpp lratchecker.cpp lrattracer.cpp lucky.cpp message.cpp minimize.cpp occs.cpp options.cpp parse.cpp phases.cpp probe.cpp profile.cpp proof.cpp propagate.cpp queue.cpp random.cpp reap.cpp reduce.cpp rephase.cpp report.cpp resources.cpp restart.cpp restore.cpp score.cpp shrink.cpp signal.cpp solution.cpp solver.cpp stable.cpp stats.cpp subsume.cpp sweep.cpp terminal.cpp ternary.cpp tier.cpp transred.cpp unstable.cpp util.cpp var.cpp veripbtracer.cpp version.cpp vivify.cpp walk.cpp walk_full_occs.cpp warmup.cpp watch.cpp
+CSOURCES := kitten.c
+OBJECTS  := $(SOURCES:.cpp=.o) $(CSOURCES:.c=.o)
+TRGT     := cadical300
+
+# gather compiler options
+CXXARGS := $(CXXFLAGS) $(INCLUDES) $(CXXOPT)
+CARGS   := $(CFLAGS) $(INCLUDES) -O3 -DNDEBUG
+
+# targets
+.PHONY: all clean lib
+
+all: lib
+
+lib: build.hpp $(OBJECTS)
+	@-ar cr lib$(TRGT).a $(OBJECTS)
+
+build.hpp:
+	@-mkdir -p build
+	@-printf 'CXX=$(CXX)\nCXXFLAGS=$(CXXFLAGS)\n' > build/makefile
+	@-cd build && ../make-build-header.sh > ../build.hpp
+
+%.o: %.cpp
+	$(CXX) $(CXXARGS) -c $< -o $@
+
+%.o: %.c
+	$(CC) $(CARGS) -c $< -o $@
+
+clean:
+	@-rm $(OBJECTS)
+	@-rm -rf build.hpp build
+
+allclean:
+	@-find . -name '*.o' -delete
+	@-find . -name '*.a' -delete
+	@-rm -rf build.hpp build
+
+#-------------------------------------------------------------------------------
